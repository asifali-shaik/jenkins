pipeline {
    agent any
    stages {
        stage('printing the hello world ') {
            steps {
                echo 'Hello world!'
            }
        }
        stage('build'){
            steps{
                echo 'building the pipeline.'
            }
        }
        stage('test'){
            steps{
                echo 'testing the application.!'
            }
        }
        stage('deploy'){
            steps{
                echo 'deploying the application'
            }
        }
    }
}
